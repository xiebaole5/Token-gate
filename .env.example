# 复制为 .env 后填入。.env 不会被提交、不上传，仅本地后端读取。
# DeepSeek API Key，用于把解析不了的杂乱日志片段交给 AI 归类（可选，不填则跳过 AI 归类）。
DEEPSEEK_API_KEY=

# MiniMax 音乐生成 API Key（必填，用于音乐盒「做一首歌」功能）
MINIMAX_API_KEY=
# MiniMax API base URL（可选，默认 https://api.minimaxi.com）
# MINIMAX_BASE_URL=https://api.minimaxi.com
# 音乐模型名称（可选，默认 music-2.6）
# MINIMAX_MUSIC_MODEL=music-2.6

# 本地后端端口（可选，默认 8787）
# TOKENGATE_PORT=8787
